# ===========================================
# GravMap Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values
# Never commit .env.local to version control!

# ===========================================
# SUPABASE (Required)
# ===========================================
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api

# Your Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Public anon key (safe to expose to client)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key (⚠️ SECRET - never expose to client!)
# Used for admin operations and cron jobs
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ===========================================
# APPLICATION (Required)
# ===========================================

# Base URL of your application
# Development: http://localhost:3000
# Production: https://yourdomain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ===========================================
# AI / OPENAI (Required)
# ===========================================
# Get your API key from: https://platform.openai.com/api-keys

# OpenAI API key for contract extraction
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===========================================
# STRIPE PAYMENTS (Required for Billing)
# ===========================================
# Get these from: https://dashboard.stripe.com/apikeys

# Stripe publishable key (safe to expose to client)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxx

# Stripe secret key (⚠️ SECRET - never expose to client!)
STRIPE_SECRET_KEY=your_stripe_secret_key_here

# Stripe webhook signing secret
# Local: Run `stripe listen --forward-to localhost:3000/api/stripe/webhook`
# Production: From Stripe Dashboard > Developers > Webhooks
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Stripe Price IDs (create products at dashboard.stripe.com/products)
# These are your actual price IDs from Stripe products

# Free Plan (if you have one)
NEXT_PUBLIC_STRIPE_PRICE_FREE=price_xxxxxxxxxxxxxx

# Pro Plan - Monthly
NEXT_PUBLIC_STRIPE_PRICE_PRO_MONTHLY=price_xxxxxxxxxxxxxx

# Pro Plan - Yearly (optional)
NEXT_PUBLIC_STRIPE_PRICE_PRO_YEARLY=price_xxxxxxxxxxxxxx

# ===========================================
# EMAIL / RESEND (Optional)
# ===========================================
# Get your API key from: https://resend.com/api-keys
# If not set, the app will run in mock mode (emails logged to console)

# Resend API key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email sender address (must match verified domain in Resend)
EMAIL_FROM=noreply@yourdomain.com

# ===========================================
# CRON JOBS (Optional but Recommended)
# ===========================================
# Used to authorize scheduled cron job requests
# Generate a random string: openssl rand -base64 32

CRON_SECRET=your-random-secret-here-change-this

# ===========================================
# SUPPORT CHAT (Optional)
# ===========================================
# Crisp or Intercom integration

# Crisp Website ID (from: https://app.crisp.chat)
NEXT_PUBLIC_CRISP_WEBSITE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# OR Intercom App ID (from: https://app.intercom.com)
# NEXT_PUBLIC_INTERCOM_APP_ID=xxxxxxxx

# ===========================================
# ANALYTICS (Optional)
# ===========================================

# Vercel Analytics (automatically enabled on Vercel)
# NEXT_PUBLIC_VERCEL_ANALYTICS_ID=xxxxxxxx

# Google Analytics
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ===========================================
# DEVELOPMENT ONLY
# ===========================================

# Skip email verification in development (optional)
# NEXT_PUBLIC_SKIP_EMAIL_VERIFICATION=true

# ===========================================
# NOTES
# ===========================================
# 
# Required to start:
# - SUPABASE_URL
# - SUPABASE_ANON_KEY
# - OPENAI_API_KEY
#
# Required for payments:
# - All STRIPE_* variables
#
# Optional but recommended:
# - RESEND_API_KEY (email notifications)
# - CRON_SECRET (secure cron jobs)
# - SUPPORT_CHAT (customer support)
#
# Development vs Production:
# - Use test Stripe keys in development
# - Use live Stripe keys in production
# - Update APP_URL for production
# - Verify email domain in Resend for production
