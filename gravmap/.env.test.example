# Test Environment Variables
# Copy this to .env.test and fill in values

# Base URL for tests
BASE_URL=http://localhost:3000

# Test user credentials (standard user)
TEST_USER_EMAIL=test@example.com
TEST_USER_PASSWORD=TestPass123!

# Free tier test user
TEST_FREE_USER_EMAIL=free@example.com
TEST_FREE_USER_PASSWORD=TestPass123!

# Pro tier test user
TEST_PRO_USER_EMAIL=pro@example.com
TEST_PRO_USER_PASSWORD=TestPass123!

# Test API keys (if needed for API testing)
# STRIPE_TEST_KEY=sk_test_xxx
# OPENAI_TEST_KEY=sk-test-xxx
