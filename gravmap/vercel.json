{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/cron/send-reminders?type=reminders&days=7,3,1",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/send-reminders?type=digest",
      "schedule": "0 8 * * *"
    }
  ],
  "headers": [
    {
      "source": "/api/cron/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, must-revalidate" }
      ]
    }
  ]
}
